post_install() {
    gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor 2>/dev/null || true
    echo "════════════════════════════════════════════════"
    echo "  Victus 16 Keyboard RGB Controller installed!"
    echo "  You can run it from the application menu or via:"
    echo "    victus16-keyboard"
    echo "  command in the terminal."
    echo "════════════════════════════════════════════════"
}

post_upgrade() {
    post_install
}

post_remove() {
    gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor 2>/dev/null || true
    echo "Victus 16 Keyboard Controller removed."
}
